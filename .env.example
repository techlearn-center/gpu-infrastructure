# GPU Infrastructure Lab - Environment Variables
# Copy this file to .env and adjust values for your environment.

# --- Kubernetes ---
KUBECONFIG=~/.kube/config
K8S_NAMESPACE=gpu-lab

# --- NVIDIA GPU Operator ---
GPU_OPERATOR_VERSION=v23.9.1
CUDA_TOOLKIT_VERSION=12.3.1

# --- GPU Time-Slicing ---
TIME_SLICING_REPLICAS=4
TIME_SLICING_RENAME_BY_DEFAULT=false

# --- MIG Configuration ---
MIG_STRATEGY=mixed          # single or mixed
MIG_PROFILE=1g.5gb          # MIG partition profile

# --- Distributed Training ---
MASTER_ADDR=localhost
MASTER_PORT=29500
WORLD_SIZE=1
RANK=0
NCCL_DEBUG=INFO
NCCL_SOCKET_IFNAME=eth0

# --- Monitoring ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
DCGM_EXPORTER_PORT=9400
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# --- Cost Optimization ---
SPOT_INSTANCE_ENABLED=false
GPU_IDLE_THRESHOLD_MINUTES=30
SCALE_DOWN_DELAY_MINUTES=10
